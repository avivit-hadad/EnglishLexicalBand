# Cloud login — same user on PC, phone, and tablet
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy URL and anon public key below
#    URL must be ONLY: https://YOUR_PROJECT.supabase.co  (no /rest/v1/ at the end!)
# 3. SQL Editor → run supabase/migrations/001_initial.sql then 002_cloud_accounts.sql
#    If you see "digest(text, unknown) does not exist", also run 003_fix_password_digest.sql
# 4. Copy this file to .env.local and fill in the values
# 5. Restart: npm run dev

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY